---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/common/Navbar.astro';
import Footer from '../components/common/Footer.astro';
---

<Layout title="Support Center - Ferro VPN">
    <Navbar />
    <main class="pt-32 pb-20 bg-bg-page min-h-screen transition-colors duration-300">
        <div class="container mx-auto px-6 max-w-4xl">
            <!-- Header -->
            <div class="text-center mb-16">
                <h1 class="text-4xl md:text-5xl font-bold mb-4 text-text-main">How can we help you?</h1>
                <p class="text-text-muted text-lg">Find answers to common questions or get in touch with our team.</p>
            </div>

            <!-- FAQ Section -->
            <div class="bg-bg-surface rounded-3xl p-8 border border-border-main mb-16 shadow-sm" x-data="{ active: null }">
                <h2 class="text-2xl font-bold text-text-main mb-8 border-b border-border-main pb-4">Frequently Asked Questions</h2>

                <div class="space-y-4">
                    <!-- FAQ 1 -->
                    <div class="border border-border-main rounded-xl overflow-hidden bg-bg-surface-secondary">
                        <button 
                            @click="active = (active === 1 ? null : 1)"
                            class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-bg-surface transition-colors focus:outline-none"
                        >
                            <span class="font-medium text-text-main">How do I connect to Ferro VPN?</span>
                            <span class="text-brand-primary text-xl font-bold" x-text="active === 1 ? '−' : '+'">+</span>
                        </button>
                        <div 
                            x-show="active === 1" 
                            x-collapse
                            class="px-6 pb-4 text-text-muted border-t border-border-main bg-bg-surface/50"
                            style="display: none;"
                        >
                            <p class="mt-4">Download the Ferro VPN app, sign in, choose a server location, and tap the "Connect" button. When the shield icon turns green, you are securely connected.</p>
                        </div>
                    </div>

                    <!-- FAQ 2 -->
                    <div class="border border-border-main rounded-xl overflow-hidden bg-bg-surface-secondary">
                        <button 
                            @click="active = (active === 2 ? null : 2)"
                            class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-bg-surface transition-colors focus:outline-none"
                        >
                            <span class="font-medium text-text-main">Why is my connection slow?</span>
                            <span class="text-brand-primary text-xl font-bold" x-text="active === 2 ? '−' : '+'">+</span>
                        </button>
                        <div 
                            x-show="active === 2" 
                            x-collapse
                            class="px-6 pb-4 text-text-muted border-t border-border-main bg-bg-surface/50"
                            style="display: none;"
                        >
                            <p class="mt-4">Speed can depend on your distance to the server. Try connecting to a server closer to your physical location. Switching protocols in the settings may also improve performance.</p>
                        </div>
                    </div>

                    <!-- FAQ 3 -->
                     <div class="border border-border-main rounded-xl overflow-hidden bg-bg-surface-secondary">
                        <button 
                            @click="active = (active === 3 ? null : 3)"
                            class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-bg-surface transition-colors focus:outline-none"
                        >
                            <span class="font-medium text-text-main">How many devices or sessions can I use?</span>
                            <span class="text-brand-primary text-xl font-bold" x-text="active === 3 ? '−' : '+'">+</span>
                        </button>
                        <div 
                            x-show="active === 3" 
                            x-collapse
                            class="px-6 pb-4 text-text-muted border-t border-border-main bg-bg-surface/50"
                            style="display: none;"
                        >
                            <p class="mt-4">Each account allows <strong>one active session at a time</strong>. This applies to all plans, including Pro. If you sign in on another device, the current session will be disconnected.</p>
                        </div>
                    </div>

                    <!-- FAQ 4 -->
                    <div class="border border-border-main rounded-xl overflow-hidden bg-bg-surface-secondary">
                        <button 
                            @click="active = (active === 4 ? null : 4)"
                            class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-bg-surface transition-colors focus:outline-none"
                        >
                            <span class="font-medium text-text-main">How do I manage or cancel my subscription?</span>
                            <span class="text-brand-primary text-xl font-bold" x-text="active === 4 ? '−' : '+'">+</span>
                        </button>
                        <div 
                            x-show="active === 4" 
                            x-collapse
                            class="px-6 pb-4 text-text-muted border-t border-border-main bg-bg-surface/50"
                            style="display: none;"
                        >
                            <p class="mt-4">Subscriptions are managed directly by the store you downloaded the app from.</p>
                            <ul class="list-disc pl-5 mt-2 space-y-1">
                                <li><strong>iOS:</strong> Go to App Store > Account > Subscriptions.</li>
                                <li><strong>Android:</strong> Go to Google Play Store > Profile > Payments & subscriptions.</li>
                            </ul>
                        </div>
                    </div>

                     <!-- FAQ 5 -->
                     <div class="border border-border-main rounded-xl overflow-hidden bg-bg-surface-secondary">
                        <button 
                            @click="active = (active === 5 ? null : 5)"
                            class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-bg-surface transition-colors focus:outline-none"
                        >
                            <span class="font-medium text-text-main">Does Ferro VPN block ads?</span>
                            <span class="text-brand-primary text-xl font-bold" x-text="active === 5 ? '−' : '+'">+</span>
                        </button>
                        <div 
                            x-show="active === 5" 
                            x-collapse
                            class="px-6 pb-4 text-text-muted border-t border-border-main bg-bg-surface/50"
                            style="display: none;"
                        >
                            <p class="mt-4">Yes! <strong>Premium users</strong> benefit from our integrated <strong>Advanced Ad Blocker</strong> technology. This powerful feature automatically blocks annoying ads, trackers, and malicious websites, giving you a cleaner, faster, and safer browsing experience.</p>
                        </div>
                    </div>

                    <!-- FAQ 6 -->
                    <div class="border border-border-main rounded-xl overflow-hidden bg-bg-surface-secondary">
                        <button 
                            @click="active = (active === 6 ? null : 6)"
                            class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-bg-surface transition-colors focus:outline-none"
                        >
                            <span class="font-medium text-text-main">Is there a free plan or trial?</span>
                            <span class="text-brand-primary text-xl font-bold" x-text="active === 6 ? '−' : '+'">+</span>
                        </button>
                        <div 
                            x-show="active === 6" 
                            x-collapse
                            class="px-6 pb-4 text-text-muted border-t border-border-main bg-bg-surface/50"
                            style="display: none;"
                        >
                            <p class="mt-4">No. Ferro VPN is a paid service and does not offer a free plan.</p>
                        </div>
                    </div>

                    <!-- FAQ 7 -->
                    <div class="border border-border-main rounded-xl overflow-hidden bg-bg-surface-secondary">
                        <button 
                            @click="active = (active === 7 ? null : 7)"
                            class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-bg-surface transition-colors focus:outline-none"
                        >
                            <span class="font-medium text-text-main">What happens if I sign in on another device?</span>
                            <span class="text-brand-primary text-xl font-bold" x-text="active === 7 ? '−' : '+'">+</span>
                        </button>
                        <div 
                            x-show="active === 7" 
                            x-collapse
                            class="px-6 pb-4 text-text-muted border-t border-border-main bg-bg-surface/50"
                            style="display: none;"
                        >
                            <p class="mt-4">Your current session will be logged out. Each account supports only one active session at a time.</p>
                        </div>
                    </div>

                    <!-- FAQ 8 -->
                    <div class="border border-border-main rounded-xl overflow-hidden bg-bg-surface-secondary">
                        <button 
                            @click="active = (active === 8 ? null : 8)"
                            class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-bg-surface transition-colors focus:outline-none"
                        >
                            <span class="font-medium text-text-main">Which devices and platforms are supported?</span>
                            <span class="text-brand-primary text-xl font-bold" x-text="active === 8 ? '−' : '+'">+</span>
                        </button>
                        <div 
                            x-show="active === 8" 
                            x-collapse
                            class="px-6 pb-4 text-text-muted border-t border-border-main bg-bg-surface/50"
                            style="display: none;"
                        >
                            <p class="mt-4">We support the platforms listed in the app stores. Please check the store listing for the latest compatibility details.</p>
                        </div>
                    </div>

                    <!-- FAQ 9 -->
                    <div class="border border-border-main rounded-xl overflow-hidden bg-bg-surface-secondary">
                        <button 
                            @click="active = (active === 9 ? null : 9)"
                            class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-bg-surface transition-colors focus:outline-none"
                        >
                            <span class="font-medium text-text-main">Do you keep activity logs?</span>
                            <span class="text-brand-primary text-xl font-bold" x-text="active === 9 ? '−' : '+'">+</span>
                        </button>
                        <div 
                            x-show="active === 9" 
                            x-collapse
                            class="px-6 pb-4 text-text-muted border-t border-border-main bg-bg-surface/50"
                            style="display: none;"
                        >
                            <p class="mt-4">No. Ferro VPN operates a strict no-logs policy as described in our Privacy Policy.</p>
                        </div>
                    </div>

                    <!-- FAQ 10 -->
                    <div class="border border-border-main rounded-xl overflow-hidden bg-bg-surface-secondary">
                        <button 
                            @click="active = (active === 10 ? null : 10)"
                            class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-bg-surface transition-colors focus:outline-none"
                        >
                            <span class="font-medium text-text-main">Why can I not access some sites while connected?</span>
                            <span class="text-brand-primary text-xl font-bold" x-text="active === 10 ? '−' : '+'">+</span>
                        </button>
                        <div 
                            x-show="active === 10" 
                            x-collapse
                            class="px-6 pb-4 text-text-muted border-t border-border-main bg-bg-surface/50"
                            style="display: none;"
                        >
                            <p class="mt-4">Some services block VPN traffic. Try switching to a different server location or disconnecting temporarily to access the site.</p>
                        </div>
                    </div>

                    <!-- FAQ 11 -->
                    <div class="border border-border-main rounded-xl overflow-hidden bg-bg-surface-secondary">
                        <button 
                            @click="active = (active === 11 ? null : 11)"
                            class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-bg-surface transition-colors focus:outline-none"
                        >
                            <span class="font-medium text-text-main">How do I change servers or regions?</span>
                            <span class="text-brand-primary text-xl font-bold" x-text="active === 11 ? '−' : '+'">+</span>
                        </button>
                        <div 
                            x-show="active === 11" 
                            x-collapse
                            class="px-6 pb-4 text-text-muted border-t border-border-main bg-bg-surface/50"
                            style="display: none;"
                        >
                            <p class="mt-4">Open the app, select your preferred location from the server list, then tap Connect.</p>
                        </div>
                    </div>

                    <!-- FAQ 12 -->
                    <div class="border border-border-main rounded-xl overflow-hidden bg-bg-surface-secondary">
                        <button 
                            @click="active = (active === 12 ? null : 12)"
                            class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-bg-surface transition-colors focus:outline-none"
                        >
                            <span class="font-medium text-text-main">Can I get a refund?</span>
                            <span class="text-brand-primary text-xl font-bold" x-text="active === 12 ? '−' : '+'">+</span>
                        </button>
                        <div 
                            x-show="active === 12" 
                            x-collapse
                            class="px-6 pb-4 text-text-muted border-t border-border-main bg-bg-surface/50"
                            style="display: none;"
                        >
                            <p class="mt-4">All sales are final except where required by law. If you purchased via Apple or Google, refunds are handled by their respective policies.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact Section -->
            <div class="text-center bg-brand-primary/10 rounded-2xl p-10 border border-brand-primary/30">
                <h3 class="text-2xl font-bold text-text-main mb-4">Still need help?</h3>
                <p class="text-text-muted mb-8">Our support team is available to assist you with any technical issues.</p>
                <a href="mailto:support@ferrovpn.com" class="inline-flex items-center px-8 py-3 rounded-xl bg-brand-primary hover:bg-brand-secondary text-white font-semibold transition-all shadow-lg hover:shadow-brand-primary/40">
                    <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                    Contact Support
                </a>
                <p class="mt-6 text-sm text-text-muted">
                    Website: <a href="https://puresoftltd.com/" class="text-brand-primary hover:text-text-main transition-colors" rel="noopener" target="_blank">https://puresoftltd.com/</a>
                </p>
            </div>
        </div>
    </main>
    <Footer />
</Layout>
